# Frontend (Vite) — copy to cof-web-vue3/.env.local
VITE_API_BASE=http://127.0.0.1:9002
VITE_WS_BASE=ws://127.0.0.1:9002

# Backend local profile uses application-local.yml (postgres / redis).
